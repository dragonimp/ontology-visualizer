    bank:indCaliber "（1）取报表查询-总行级战略性集团客户盈利情况表（汇总）-固定报表。下载对应报告期的业务数据； （2）会计期间选择对应报告期，机构选择建行境内汇总虚拟机构，报表口径选披露口径，报表类型选央企及全球客户，币种选T01，单位选亿元，成员单位是否汇总选择“是”，展现指标选择明细指标，是否集团客户部责任客户不选择或选择是或选择是。下载得到战客部管辖集团管会明细数据， （3）净利润产出率=合计维度的净利润÷(存款年日均余额+贷款年日均余额)×年化系数×100%   注：年化系数=12/年初到报告期月数 3、不同口径的取数规则： 考核口径：“是否集团客户部责任客户=是”； 全量口径，“是否集团客户部责任客户”不选择。"@zh ;
    bank:indDept ""@zh ;
    bank:unit "%"@zh ;
    bank:statFreq "月"@zh
 .

