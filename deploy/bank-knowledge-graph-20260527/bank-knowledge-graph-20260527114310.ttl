@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix bank: <http://purl.org/bank/ontology/> .
@prefix bankd: <http://purl.org/bank/data/> .

<http://purl.org/bank/ontology> a owl:Ontology ;
    rdfs:label "银行指标知识库本体"@zh ;
    owl:versionInfo "3.0" ;
    rdfs:comment "2026-05-26 构建"@zh .

# ===== 顶级类体系 =====
<http://purl.org/bank/ontology/Indicator> a owl:Class ;
    rdfs:label "指标"@zh ;
    rdfs:comment "银行指标体系顶级类"@zh .

<http://purl.org/bank/ontology/IndicatorType> a owl:Class ;
    rdfs:label "指标类型"@zh ;
    rdfs:comment "按指标属性归类的体系"@zh .

<http://purl.org/bank/ontology/BalanceIndicator> a owl:Class ;
    rdfs:label "余额类指标"@zh ;
    rdfs:comment "统计余额的指标"@zh .

<http://purl.org/bank/ontology/CustomerCountIndicator> a owl:Class ;
    rdfs:label "客户数类指标"@zh ;
    rdfs:comment "统计客户数量的指标"@zh .

<http://purl.org/bank/ontology/RatioIndicator> a owl:Class ;
    rdfs:label "比率类指标"@zh ;
    rdfs:comment "比率/百分比指标"@zh .

<http://purl.org/bank/ontology/TransactionCountIndicator> a owl:Class ;
    rdfs:label "交易笔数类指标"@zh ;
    rdfs:comment "统计交易笔数的指标"@zh .

<http://purl.org/bank/ontology/AccountCountIndicator> a owl:Class ;
    rdfs:label "账户数类指标"@zh ;
    rdfs:comment "统计账户数量的指标"@zh .

<http://purl.org/bank/ontology/AmountIndicator> a owl:Class ;
    rdfs:label "金额类指标"@zh ;
    rdfs:comment "统计金额相关指标的类"@zh .

<http://purl.org/bank/ontology/OtherIndicator> a owl:Class ;
    rdfs:label "其他类指标"@zh ;
    rdfs:comment "其他类型指标的类"@zh .

<http://purl.org/bank/ontology/ScenarioClassification> a owl:Class ;
    rdfs:label "场景分类"@zh ;
    rdfs:comment "按业务场景归类的体系"@zh .

<http://purl.org/bank/ontology/BusinessCategory> a owl:Class ;
    rdfs:label "业务分类"@zh ;
    rdfs:comment "按资产业务归类的体系"@zh .

<http://purl.org/bank/ontology/CustomerDimension> a owl:Class ;
    rdfs:label "客户维度"@zh ;
    rdfs:comment "客户类型维度"@zh .

<http://purl.org/bank/ontology/ProductDimension> a owl:Class ;
    rdfs:label "产品维度"@zh ;
    rdfs:comment "产品类型维度"@zh .

<http://purl.org/bank/ontology/ChannelDimension> a owl:Class ;
    rdfs:label "渠道维度"@zh ;
    rdfs:comment "服务渠道维度"@zh .

<http://purl.org/bank/ontology/InterbankDimension> a owl:Class ;
    rdfs:label "同业维度"@zh ;
    rdfs:comment "同业机构维度"@zh .

<http://purl.org/bank/ontology/OtherDimension> a owl:Class ;
    rdfs:label "其他维度"@zh ;
    rdfs:comment "其他分析维度"@zh .

<http://purl.org/bank/ontology/BalanceIndicator> rdfs:subClassOf bank:IndicatorType ;
    rdfs:subClassOf bank:Indicator .

<http://purl.org/bank/ontology/CustomerCountIndicator> rdfs:subClassOf bank:IndicatorType ;
    rdfs:subClassOf bank:Indicator .

<http://purl.org/bank/ontology/RatioIndicator> rdfs:subClassOf bank:IndicatorType ;
    rdfs:subClassOf bank:Indicator .

<http://purl.org/bank/ontology/TransactionCountIndicator> rdfs:subClassOf bank:IndicatorType ;
    rdfs:subClassOf bank:Indicator .

<http://purl.org/bank/ontology/AccountCountIndicator> rdfs:subClassOf bank:IndicatorType ;
    rdfs:subClassOf bank:Indicator .

<http://purl.org/bank/ontology/AmountIndicator> rdfs:subClassOf bank:IndicatorType ;
    rdfs:subClassOf bank:Indicator .

<http://purl.org/bank/ontology/OtherIndicator> rdfs:subClassOf bank:IndicatorType ;
    rdfs:subClassOf bank:Indicator .

# ===== 数据属性 =====
<http://purl.org/bank/ontology/indName> a owl:DatatypeProperty ;
    rdfs:label "指标名称"@zh ;
    rdfs:domain bank:Indicator ;
    rdfs:range xsd:string .

<http://purl.org/bank/ontology/indCode> a owl:DatatypeProperty ;
    rdfs:label "指标编号"@zh ;
    rdfs:domain bank:Indicator ;
    rdfs:range xsd:string .

<http://purl.org/bank/ontology/indDef> a owl:DatatypeProperty ;
    rdfs:label "指标定义"@zh ;
    rdfs:domain bank:Indicator ;
    rdfs:range xsd:string .

<http://purl.org/bank/ontology/indCaliber> a owl:DatatypeProperty ;
    rdfs:label "指标口径"@zh ;
    rdfs:domain bank:Indicator ;
    rdfs:range xsd:string .

<http://purl.org/bank/ontology/indDept> a owl:DatatypeProperty ;
    rdfs:label "主责部门"@zh ;
    rdfs:domain bank:Indicator ;
    rdfs:range xsd:string .

<http://purl.org/bank/ontology/unit> a owl:DatatypeProperty ;
    rdfs:label "单位"@zh ;
    rdfs:domain bank:Indicator ;
    rdfs:range xsd:string .

<http://purl.org/bank/ontology/statFreq> a owl:DatatypeProperty ;
    rdfs:label "统计频度"@zh ;
    rdfs:domain bank:Indicator ;
    rdfs:range xsd:string .

# ===== 对象属性 =====
<http://purl.org/bank/ontology/belongsToScenario> a owl:ObjectProperty ;
    rdfs:label "属于场景"@zh ;
    rdfs:domain bank:Indicator ;
    rdfs:range bank:ScenarioClassification ;
    rdfs:comment "指标属于场景分类"@zh .

<http://purl.org/bank/ontology/belongsToBusiness> a owl:ObjectProperty ;
    rdfs:label "属于业务"@zh ;
    rdfs:domain bank:Indicator ;
    rdfs:range bank:BusinessCategory ;
    rdfs:comment "指标属于业务分类"@zh .

<http://purl.org/bank/ontology/hasDimension> a owl:ObjectProperty ;
    rdfs:label "具有维度"@zh ;
    rdfs:domain bank:Indicator ;
    rdfs:range bank:Dimension ;
    rdfs:comment "指标具有维度"@zh .

# ===== 维度类 =====
<http://purl.org/bank/ontology/对公客户> a owl:Class ;
    rdfs:label "对公客户"@zh ;
    rdfs:subClassOf bank:CustomerDimension .

<http://purl.org/bank/ontology/对私客户> a owl:Class ;
    rdfs:label "对私客户"@zh ;
    rdfs:subClassOf bank:CustomerDimension .

<http://purl.org/bank/ontology/小微客户> a owl:Class ;
    rdfs:label "小微客户"@zh ;
    rdfs:subClassOf bank:CustomerDimension .

<http://purl.org/bank/ontology/存款> a owl:Class ;
    rdfs:label "存款"@zh ;
    rdfs:subClassOf bank:ProductDimension .

<http://purl.org/bank/ontology/贷款> a owl:Class ;
    rdfs:label "贷款"@zh ;
    rdfs:subClassOf bank:ProductDimension .

<http://purl.org/bank/ontology/理财> a owl:Class ;
    rdfs:label "理财"@zh ;
    rdfs:subClassOf bank:ProductDimension .

<http://purl.org/bank/ontology/信用卡> a owl:Class ;
    rdfs:label "信用卡"@zh ;
    rdfs:subClassOf bank:ProductDimension .

<http://purl.org/bank/ontology/结算> a owl:Class ;
    rdfs:label "结算"@zh ;
    rdfs:subClassOf bank:ProductDimension .

<http://purl.org/bank/ontology/外汇> a owl:Class ;
    rdfs:label "外汇"@zh ;
    rdfs:subClassOf bank:ProductDimension .

<http://purl.org/bank/ontology/投资> a owl:Class ;
    rdfs:label "投资"@zh ;
    rdfs:subClassOf bank:ProductDimension .

<http://purl.org/bank/ontology/承兑> a owl:Class ;
    rdfs:label "承兑"@zh ;
    rdfs:subClassOf bank:ProductDimension .

<http://purl.org/bank/ontology/票据> a owl:Class ;
    rdfs:label "票据"@zh ;
    rdfs:subClassOf bank:ProductDimension .

<http://purl.org/bank/ontology/手机银行> a owl:Class ;
    rdfs:label "手机银行"@zh ;
    rdfs:subClassOf bank:ChannelDimension .

<http://purl.org/bank/ontology/网上银行> a owl:Class ;
    rdfs:label "网上银行"@zh ;
    rdfs:subClassOf bank:ChannelDimension .

<http://purl.org/bank/ontology/柜面> a owl:Class ;
    rdfs:label "柜面"@zh ;
    rdfs:subClassOf bank:ChannelDimension .

<http://purl.org/bank/ontology/ATM> a owl:Class ;
    rdfs:label "ATM"@zh ;
    rdfs:subClassOf bank:ChannelDimension .

<http://purl.org/bank/ontology/微信> a owl:Class ;
    rdfs:label "微信"@zh ;
    rdfs:subClassOf bank:ChannelDimension .

<http://purl.org/bank/ontology/银行类型> a owl:Class ;
    rdfs:label "银行类型"@zh ;
    rdfs:subClassOf bank:InterbankDimension .

<http://purl.org/bank/ontology/银行同业> a owl:Class ;
    rdfs:label "银行同业"@zh ;
    rdfs:subClassOf bank:InterbankDimension .

<http://purl.org/bank/ontology/来源系统> a owl:Class ;
    rdfs:label "来源系统"@zh ;
    rdfs:subClassOf bank:OtherDimension .

<http://purl.org/bank/ontology/组织层级> a owl:Class ;
    rdfs:label "组织层级"@zh ;
    rdfs:subClassOf bank:OtherDimension .

<http://purl.org/bank/ontology/指标频度> a owl:Class ;
    rdfs:label "指标频度"@zh ;
    rdfs:subClassOf bank:OtherDimension .

<http://purl.org/bank/ontology/指标方向> a owl:Class ;
    rdfs:label "指标方向"@zh ;
    rdfs:subClassOf bank:OtherDimension .

