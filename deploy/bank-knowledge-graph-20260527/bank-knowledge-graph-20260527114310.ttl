<http://purl.org/bank/data/10000960> a bank:BalanceIndicator, bank:Indicator ;
    rdfs:label "个人活期存款余额"@zh ;
    rdfs:comment "个人活期存款余额：指截至统计时点，按机构维度统计当前个人活期存款的余额。"@zh ;
    bank:indCode "10000960"^^xsd:string ;
    bank:indDef "指截至统计时点，按机构维度统计当前个人活期存款的余额。"@zh ;
    bank:indCaliber "个人活期存款（财会科目号：2301）的余额。"@zh ;
    bank:indDept "个人金融部（消费者权益保护部）"@zh ;
    bank:unit "元"@zh ;
    bank:statFreq "日"@zh
 .

