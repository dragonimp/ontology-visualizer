<http://purl.org/bank/data/I00022113> a bank:BalanceIndicator, bank:Indicator ;
    rdfs:label "不良贷款余额（监管口径）"@zh ;
    rdfs:comment "不良贷款余额（监管口径）：指截至统计时点，按机构维度统计当前不良贷款余额（金监总局口径），根据原银保监会2023年非现场监管报表填报说明，不良贷款余额指标为衍生指标，由报表中次级类、可疑类、损失类贷款余额加总计算得出。数据来源为（原）银保监会通过信息采集平台发布的同业共享数据。"@zh ;
    bank:indCode "I00022113"^^xsd:string ;
    bank:indDef "指截至统计时点，按机构维度统计当前不良贷款余额（金监总局口径），根据原银保监会2023年非现场监管报表填报说明，不良贷款余额指标为衍生指标，由报表中次级类、可疑类、损失类贷款余额加总计算得出。数据来源为（原）银保监会通过信息采集平台发布的同业共享数据。"@zh ;
    bank:indCaliber "SMIS中手工补录的同业交换数据。"@zh ;
    bank:indDept "信贷管理部"@zh ;
    bank:unit "元"@zh ;
    bank:statFreq "月"@zh
 .

