    bank:indDef ""@zh ;
    bank:indCaliber "截至统计时点，按机构维度统计数字经济核心产业贷款余额（经营参考）。该指标根据金融“五篇大文章”总体统计制度按日计算加工，与监管报送数据或存在差异，不得对外使用。指金融机构发放、实际投向数字经济核心产业的贷款，包括数字产品制造业贷款、数字产品服务业贷款、数字技术应用业贷款、数字要素驱动业贷款。数字经济核心产业贷款余额等于数字产品制造业贷款、数字产品服务业贷款、数字技术应用业贷款、数字要素驱动业贷款的去重合计余额。数字经济核心产业贷款的认定按国家统计局印发的《数字经济及其核心产业统计分类（2021）（国家统计局令第33号）》执行。 数字经济核心产业贷款产品范围包括透支、经营贷款、固定资产贷款、融资租赁、贸易融资、并购贷款、从非金融机构买入返售资产、各项垫款、票据融资（直贴），不含二级市场福费廷和再保理，不含注册地址在境外的客户贷款。"@zh ;
    bank:indDept ""@zh ;
    bank:unit ""@zh ;
    bank:statFreq "日"@zh
 .

<http://purl.org/bank/data/YW_SCA_LOA_1046> a bank:BalanceIndicator, bank:Indicator ;
    rdfs:label "数字产品制造业贷款余额（经营参考）"@zh ;
