<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>本体知识图谱可视化</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/three@0.128.0/examples/js/controls/OrbitControls.js"></script>
    <script src="https://unpkg.com/n3@1.17.1/browser/n3.min.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, 'Microsoft YaHei', 'PingFang SC', sans-serif; background: #1a1a2e; color: #e0e0e0; overflow: hidden; -webkit-tap-highlight-color: transparent; }
        #canvas-container { width: 100vw; height: 100vh; position: fixed; top: 0; left: 0; touch-action: manipulation; }
        
        /* 侧边栏 - 桌面端固定宽度，移动端可折叠 */
        .sidebar {
            position: fixed; top: 0; left: 0; width: 300px; height: 100vh;
            background: rgba(16, 16, 36, 0.95); border-right: 1px solid #333;
            padding: 20px; overflow-y: auto; z-index: 100;
            transition: transform 0.3s ease;
        }
        .sidebar-toggle {
            display: none; position: fixed; top: 10px; left: 10px;
            z-index: 101; background: rgba(16, 16, 36, 0.95);
            border: 1px solid #444; border-radius: 6px; padding: 8px 12px;
            color: #00d4ff; font-size: 1.2em; cursor: pointer;
        }
        .sidebar h1 { font-size: 1.3em; margin-bottom: 5px; color: #00d4ff; }
        .sidebar .subtitle { font-size: 0.8em; color: #888; margin-bottom: 20px; }
        .section { margin-bottom: 20px; }
        .section h3 { font-size: 0.95em; color: #00d4ff; margin-bottom: 10px; padding-bottom: 5px; border-bottom: 1px solid #333; }
        .btn-group { display: flex; gap: 8px; flex-wrap: wrap; }
        .btn {
            padding: 8px 14px; border: 1px solid #444; background: rgba(0, 212, 255, 0.1);
            color: #e0e0e0; border-radius: 6px; cursor: pointer; font-size: 0.85em;
            transition: all 0.3s;
        }
        .btn:hover, .btn.active { background: rgba(0, 212, 255, 0.3); border-color: #00d4ff; }
        .btn-import {
            width: 100%; padding: 12px; background: rgba(76, 175, 80, 0.15);
            border: 1px dashed #4CAF50; margin-bottom: 10px;
        }
        .btn-import:hover { background: rgba(76, 175, 80, 0.3); }
        .stats { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
        .stat-item {
            background: rgba(0, 212, 255, 0.05); border: 1px solid #333;
            border-radius: 8px; padding: 12px; text-align: center;
        }
        .stat-value { font-size: 1.8em; font-weight: bold; color: #00d4ff; }
        .stat-label { font-size: 0.75em; color: #888; margin-top: 4px; }
        #loading-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(26, 26, 46, 0.95); display: flex;
            flex-direction: column; align-items: center; justify-content: center;
            z-index: 1000; transition: opacity 0.5s;
        }
        #loading-overlay.hidden { opacity: 0; pointer-events: none; }
        .spinner {
            width: 50px; height: 50px; border: 3px solid #333;
            border-top-color: #00d4ff; border-radius: 50%;
            animation: spin 1s linear infinite; margin-bottom: 15px;
        }
        @keyframes spin { to { transform: rotate(360deg); } }
        .legend { position: fixed; bottom: 20px; right: 20px; background: rgba(16, 16, 36, 0.9);
            border: 1px solid #333; border-radius: 10px; padding: 15px; z-index: 100;
        }
        .legend h4 { font-size: 0.85em; color: #00d4ff; margin-bottom: 10px; }
        .legend-item { display: flex; align-items: center; margin-bottom: 6px; font-size: 0.8em; }
        .legend-dot { width: 12px; height: 12px; border-radius: 50%; margin-right: 8px; }
        #detail-panel {
            position: fixed; top: 20px; right: 20px; width: 280px;
            background: rgba(16, 16, 36, 0.95); border: 1px solid #333;
            border-radius: 10px; padding: 15px; z-index: 100;
            display: none;
        }
        #detail-panel h4 { color: #00d4ff; margin-bottom: 10px; }
        #detail-panel .prop { font-size: 0.85em; margin-bottom: 5px; }
        #detail-panel .prop span { color: #888; }
        .btn-close {
            position: absolute; top: 10px; right: 10px; background: none;
            border: none; color: #888; cursor: pointer; font-size: 1.2em;
        }
        .btn-close:hover { color: #e0e0e0; }
        .status-bar { position: fixed; top: 10px; right: 20px; font-size: 0.8em; color: #888; z-index: 100; }
        .btn-export { width: 100%; padding: 10px; background: rgba(156, 39, 176, 0.15);
            border-color: #9C27B0; margin-top: 10px;
        }
        .btn-export:hover { background: rgba(156, 39, 176, 0.3); }
        /* 搜索框样式 */
        .search-box {
            width: 100%;
            padding: 8px 12px;
            background: rgba(0, 0, 0, 0.3);
            border: 1px solid #444;
            border-radius: 6px;
            color: #e0e0e0;
            font-size: 0.85em;
            outline: none;
            transition: border-color 0.3s;
        }
        .search-box:focus {
            border-color: #00d4ff;
        }
        .search-box::placeholder {
            color: #666;
        }
        .label-toggle {
            margin-top: 8px;
        }
        #error-message {
            position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%);
            background: rgba(244, 67, 54, 0.9); color: white; padding: 20px;
            border-radius: 10px; z-index: 2000; display: none; text-align: center;
            max-width: 400px;
        }
        #error-message button {
            margin-top: 10px; padding: 8px 16px; background: white;
            color: #f44336; border: none; border-radius: 5px; cursor: pointer;
        }
        /* 移动端适配 */
        @media (max-width: 768px) {
            .sidebar-toggle { display: block; }
            .sidebar {
                width: 280px; transform: translateX(-100%);
                padding: 15px;
            }
            .sidebar.open { transform: translateX(0); }
            .sidebar h1 { font-size: 1.1em; }
            .stat-item { padding: 8px; }
            .stat-value { font-size: 1.4em; }
            .legend { bottom: 10px; right: 10px; padding: 10px; }
            .legend h4 { font-size: 0.75em; }
            #detail-panel { width: 260px; top: 50px; right: 10px; }
            .status-bar { right: 10px; font-size: 0.7em; top: 15px; }
        }
    </style>
</head>
<body>

<button class="sidebar-toggle" id="sidebar-toggle" onclick="toggleSidebar()">☰</button>

<div id="loading-overlay">
    <div class="spinner"></div>
    <div id="loading-text">正在加载本体数据...</div>
</div>

<div id="error-message">
    <div id="error-text"></div>
    <button onclick="hideError()">继续查看</button>
</div>

<div id="canvas-container"></div>

<div class="sidebar" id="sidebar">
    <h1>本体知识图谱</h1>
    <div class="subtitle">Ontology Knowledge Graph</div>
    
    <div class="section">
        <h3>展示模式</h3>
        <div class="btn-group">
            <button class="btn active" data-mode="classes" onclick="setMode('classes')">仅类</button>
            <button class="btn" data-mode="props" onclick="setMode('props')">类 + 属性</button>
            <button class="btn" data-mode="full" onclick="setMode('full')">全量</button>
        </div>
    </div>
    
    <div class="section">
        <h3>选项</h3>
        <div class="btn-group">
            <button class="btn active" id="btn-instances" onclick="toggleInstances()">显示实例</button>
            <button class="btn active" id="btn-dataprops" onclick="toggleDataProps()">显示数据属性</button>
        </div>
        <div class="btn-group" style="margin-top:8px;">
            <button class="btn" id="btn-hide-leaves" onclick="toggleHideLeaves()">隐藏叶子类</button>
        </div>
        <div class="label-toggle">
            <button class="btn" id="btn-label-toggle" onclick="toggleLabelSource()" style="width:100%;">显示: Label</button>
        </div>
    </div>
    
    <div class="section">
        <h3>搜索节点</h3>
        <input type="text" class="search-box" id="search-input" placeholder="输入关键词搜索..." oninput="handleSearch(event)">
    </div>
    
    <div class="section">
    <div class="section">
        <h3>选择知识文件</h3>
        <div class="file-select-wrapper">
            <select id="file-select" onchange="handleFileSelect(event)">
                <option value="">-- 选择文件 --</option>
            </select>
        </div>
        <button class="btn btn-import" onclick="document.getElementById('file-input').click()" style="margin-top: 8px;">
            📁 手动导入文件
        </button>
        <input type="file" id="file-input" accept=".ttl,.rdf,.n3,.nt" style="display:none" onchange="handleFileUpload(event)">
    </div>
    
    <div class="section">
        <h3>统计</h3>
        <div class="stats">
            <div class="stat-item">
                <div class="stat-value" id="stat-classes">0</div>
                <div class="stat-label">类</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="stat-instances">0</div>
                <div class="stat-label">实例</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="stat-objprops">0</div>
                <div class="stat-label">对象属性</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="stat-dataprops">0</div>
                <div class="stat-label">数据属性</div>
            </div>
        </div>
    </div>
    
    <div class="section">
        <h3>导出</h3>
        <button class="btn btn-export" onclick="exportPNG()">📷 导出 PNG</button>
    </div>
</div>

<div class="legend">
    <h4>图例</h4>
    <div class="legend-item"><div class="legend-dot" style="background:#4FC3F7"></div>类（可展开）</div>
    <div class="legend-item"><div class="legend-dot" style="border:2px dashed #4FC3F7; background:transparent;"></div>类（不可展开）</div>
    <div class="legend-item" id="legend-hidden-classes" style="color:#FFB74D;font-weight:bold;"></div>
    <div class="legend-item"><div class="legend-dot" style="background:#81C784"></div>实例</div>
    <div class="legend-item"><div class="legend-dot" style="background:#FFB74D"></div>对象属性</div>
    <div class="legend-item"><div class="legend-dot" style="background:#E57373"></div>数据属性</div>
    <div class="legend-item" style="margin-top:10px;font-size:0.75em;color:#888;">点击类节点可展开/折叠子类</div>
</div>

<div id="detail-panel">
    <button class="btn-close" onclick="closeDetail()">✕</button>
    <h4 id="detail-title">详情</h4>
    <div id="detail-content"></div>
</div>

<div class="status-bar" id="status-bar">等待加载...</div>

<script>
var scene, camera, renderer, controls;
var nodeObjects = [];
var edgeObjects = [];
var ontologyData = { classes: {}, instances: {}, objProps: {}, datProps: {}, edges: [] };
var currentMode = 'classes';
var showInstances = true;
var showDataProps = true;
var hideLeavesMode = false;  // 是否隐藏叶子类
var labelSourceType = 'label';  // 'label' 或 'uri'，默认显示label
var searchQuery = '';  // 搜索关键词

var nodeColors = {
    'class': 0x4FC3F7,
    'instance': 0x81C784,
    'objProp': 0xFFB74D,
    'datProp': 0xE57373
};

var selectedNode = null;
var originalMaterials = [];

function toggleSidebar() {
    document.getElementById('sidebar').classList.toggle('open');
}

function initThree() {
    var container = document.getElementById('canvas-container');
    scene = new THREE.Scene();
    
    // 深空渐变背景
    scene.background = new THREE.Color(0x0a0a1a);
    scene.fog = new THREE.FogExp2(0x0a0a1a, 0.0008);
    
    camera = new THREE.PerspectiveCamera(60, window.innerWidth / window.innerHeight, 0.1, 5000);
    camera.position.set(80, 60, 180);
    
    renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.2;
    container.appendChild(renderer.domElement);
    
    controls = new THREE.OrbitControls(camera, renderer.domElement);
    controls.enableDamping = true;
    controls.dampingFactor = 0.05;
    controls.minDistance = 30;
    controls.maxDistance = 800;
    
    // ========== 多重光源系统 ==========
    // 环境光（基础照明）
    var ambientLight = new THREE.AmbientLight(0x303050, 0.8);
    scene.add(ambientLight);
    
    // 主方向光（模拟顶光）
    var dirLight = new THREE.DirectionalLight(0xffffff, 1.5);
    dirLight.position.set(100, 200, 100);
    dirLight.castShadow = true;
    scene.add(dirLight);
    
    // 蓝色补光（左侧冷光）
    var blueLight = new THREE.PointLight(0x4FC3F7, 2, 500);
    blueLight.position.set(-150, 50, -100);
    scene.add(blueLight);
    
    // 紫色补光（右侧暖光）
    var purpleLight = new THREE.PointLight(0x9C27B0, 1.5, 500);
    purpleLight.position.set(150, 80, 100);
    scene.add(purpleLight);
    
    // 底部反光
    var bottomLight = new THREE.PointLight(0x1a237e, 1, 600);
    bottomLight.position.set(0, -200, 0);
    scene.add(bottomLight);
    
    // 移除网格，改用粒子星空背景
    // var gridHelper = new THREE.GridHelper(500, 20, 0x333333, 0x222222);
    // scene.add(gridHelper);
    
    // 粒子星空背景
    createStarfield();
    
    window.addEventListener('resize', onResize);
    
    var raycaster = new THREE.Raycaster();
    var mouse = new THREE.Vector2();
    var clickTimer = null;
    var pendingClickNode = null;
    var isTouchDevice = false;

    function handleNodeTap(clientX, clientY) {
        // 如果是touchstart触发了，后续click也要跳过
        if (!isTouchDevice) return;
        isTouchDevice = false;
        handleNodeTapInternal(clientX, clientY);
    }

    function handleNodeTapInternal(clientX, clientY) {
        mouse.x = (clientX / window.innerWidth) * 2 - 1;
        mouse.y = -(clientY / window.innerHeight) * 2 + 1;
        raycaster.setFromCamera(mouse, camera);
        var intersects = raycaster.intersectObjects(nodeObjects);
        if (intersects.length > 0) {
            pendingClickNode = intersects[0].object;
        } else {
            pendingClickNode = null;
        }
        
        if (clickTimer) {
            // 双击
            clearTimeout(clickTimer);
            clickTimer = null;
            if (pendingClickNode) {
                handleDoubleClick(pendingClickNode);
            }
            pendingClickNode = null;
        } else {
            // 等待确认是否为双击
            clickTimer = setTimeout(function() {
                if (pendingClickNode) {
                    // 单击处理：类节点点击切换展开/折叠/显示
                    if (pendingClickNode.userData.type === 'class') {
                        toggleClassExpand(pendingClickNode.userData.id);
                    } else {
                        selectNode(pendingClickNode);
                    }
                }
                pendingClickNode = null;
                clickTimer = null;
            }, 350);
        }
    }

    renderer.domElement.addEventListener('click', function(e) {
        handleNodeTap(e.clientX, e.clientY);
    });

    renderer.domElement.addEventListener('touchstart', function(e) {
        if (e.touches.length === 1) {
            isTouchDevice = true;
            e.preventDefault();
            handleNodeTapInternal(e.touches[0].clientX, e.touches[0].clientY);
        }
    }, { passive: false });
    
    animate();
}

// ========== 粒子星空背景 ==========\nfunction createStarfield() {
    var starCount = 1500;
    var starGeometry = new THREE.BufferGeometry();
    var starPositions = new Float32Array(starCount * 3);
    var starColors = new Float32Array(starCount * 3);
    
    for (var i = 0; i < starCount; i++) {
        // 随机分布在球形空间内
        var theta = Math.random() * Math.PI * 2;
        var phi = Math.acos(2 * Math.random() - 1);
        var radius = 800 + Math.random() * 1200;
        
        starPositions[i * 3] = radius * Math.sin(phi) * Math.cos(theta);
        starPositions[i * 3 + 1] = radius * Math.sin(phi) * Math.sin(theta);
        starPositions[i * 3 + 2] = radius * Math.cos(phi);
        
        // 星星颜色变化：蓝白到淡紫
        var colorChoice = Math.random();
        if (colorChoice < 0.6) {
            starColors[i * 3] = 0.8 + Math.random() * 0.2;
            starColors[i * 3 + 1] = 0.85 + Math.random() * 0.15;
            starColors[i * 3 + 2] = 1.0;
        } else {
            starColors[i * 3] = 0.7 + Math.random() * 0.2;
            starColors[i * 3 + 1] = 0.6 + Math.random() * 0.2;
            starColors[i * 3 + 2] = 0.9 + Math.random() * 0.1;
        }
    }
    
    starGeometry.setAttribute('position', new THREE.BufferAttribute(starPositions, 3));
    starGeometry.setAttribute('color', new THREE.BufferAttribute(starColors, 3));
    
    var starMaterial = new THREE.PointsMaterial({
        size: 1.5,
        vertexColors: true,
        transparent: true,
        opacity: 0.8,
        sizeAttenuation: true
    });
    
    var stars = new THREE.Points(starGeometry, starMaterial);
    scene.add(stars);
}

function animate() {
    requestAnimationFrame(animate);
    controls.update();
    
    // 缓慢旋转场景（营造沉浸感）
    scene.rotation.y += 0.0003;
    
    renderer.render(scene, camera);
}

function onResize() {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
}

// 节点选择和高亮功能
function selectNode(mesh) {
    // 如果点击的是已选中的节点，取消选择
    if (selectedNode === mesh) {
        deselectAll();
        return;
    }
    
    // 保存当前选中节点并取消高亮
    if (selectedNode) {
        restoreNodeMaterial(selectedNode);
    }
    
    // 保存所有节点的原始材质
    if (originalMaterials.length === 0) {
        for (var i = 0; i < nodeObjects.length; i++) {
            originalMaterials.push(nodeObjects[i].material);
        }
    }
    
    // 高亮选中的节点
    selectNodeAndHighlight(mesh);
    
    // 更新详情面板
    showDetail(mesh);
}

function selectNodeAndHighlight(mesh) {
    selectedNode = mesh;
    
    // 设置选中节点的高亮样式
    var selectedColor = 0xFFFFFF; // 白色高亮
    var selectedEmissive = 0xFFFF00; // 黄色发光
    
    mesh.material.color.setHex(selectedColor);
    mesh.material.emissive.setHex(selectedEmissive);
    mesh.material.emissiveIntensity = 0.8;
    mesh.material.opacity = 1.0;
    
    // 放大选中的节点
    var originalScale = mesh.scale.clone();
    mesh.scale.multiplyScalar(1.3);
    mesh.userData.originalScale = originalScale;
    
    // 移动其他节点变暗
    for (var i = 0; i < nodeObjects.length; i++) {
        var node = nodeObjects[i];
        if (node !== mesh) {
            node.material.opacity = 0.3;
        }
    }
    
    // 相机聚焦到选中节点
    focusCameraOnNode(mesh);
}

function focusCameraOnNode(mesh) {
    var targetPosition = mesh.position.clone();
    var cameraOffset = new THREE.Vector3(20, 15, 20); // 相机偏移量
    
    // 计算目标相机位置
    var targetCameraPos = targetPosition.clone().add(cameraOffset);
    
    // 平滑过渡动画
    var startPos = camera.position.clone();
    var startTarget = controls.target.clone();
    var endTarget = targetPosition.clone();
    
    var duration = 800; // 动画持续时间（毫秒）
    var startTime = Date.now();
    
    function animateCamera() {
        var elapsed = Date.now() - startTime;
        var progress = Math.min(elapsed / duration, 1);
        
        // 使用缓动函数
        var easeProgress = easeInOutCubic(progress);
        
        // 插值相机位置
        camera.position.lerpVectors(startPos, targetCameraPos, easeProgress);
        
        // 插值控制器目标点
        controls.target.lerpVectors(startTarget, endTarget, easeProgress);
        controls.update();
        
        if (progress < 1) {
            requestAnimationFrame(animateCamera);
        }
    }
    
    animateCamera();
}

function easeInOutCubic(t) {
    return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
}

function restoreNodeMaterial(mesh) {
    if (!mesh) return;
    
    // 恢复原始材质
    var index = nodeObjects.indexOf(mesh);
    if (index >= 0 && originalMaterials[index]) {
        mesh.material = originalMaterials[index];
    }
    
    // 恢复原始缩放
    if (mesh.userData.originalScale) {
        mesh.scale.copy(mesh.userData.originalScale);
    }
}

function deselectAll() {
    // 清除选中节点
    if (selectedNode) {
        restoreNodeMaterial(selectedNode);
        selectedNode = null;
    }
    
    // 恢复所有节点的不透明度
    for (var i = 0; i < nodeObjects.length; i++) {
        nodeObjects[i].material.opacity = 0.9;
    }
    
    // 重置相机到默认位置
    resetCameraToDefault();
    
    // 关闭详情面板
    closeDetail();
}

function resetCameraToDefault() {
    var startPos = camera.position.clone();
    var startTarget = controls.target.clone();
    var endPos = new THREE.Vector3(0, 50, 200);
    var endTarget = new THREE.Vector3(0, 0, 0);
    
    var duration = 600;
    var startTime = Date.now();
    
    function animateCamera() {
        var elapsed = Date.now() - startTime;
        var progress = Math.min(elapsed / duration, 1);
        
        var easeProgress = easeInOutCubic(progress);
        
        camera.position.lerpVectors(startPos, endPos, easeProgress);
        controls.target.lerpVectors(startTarget, endTarget, easeProgress);
        controls.update();
        
        if (progress < 1) {
            requestAnimationFrame(animateCamera);
        }
    }
    
    animateCamera();
}

// 生成文字标签精灵
function createLabel(label, fontSize) {
    var canvas = document.createElement('canvas');
    var ctx = canvas.getContext('2d');
    // 自适应画布宽度
    ctx.font = 'bold ' + fontSize + 'px -apple-system, Microsoft YaHei, sans-serif';
    var textWidth = ctx.measureText(label).width;
    canvas.width = Math.max(128, textWidth + 20);
    canvas.height = 48;
    
    ctx.font = 'bold ' + fontSize + 'px -apple-system, Microsoft YaHei, sans-serif';
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    
    // 半透明背景
    ctx.fillStyle = 'rgba(0, 0, 0, 0.4)';
    var padding = 6;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    
    // 文字
    ctx.fillStyle = '#ffffff';
    ctx.shadowColor = 'rgba(0, 0, 0, 0.8)';
    ctx.shadowBlur = 4;
    ctx.fillText(label, canvas.width / 2, canvas.height / 2);
    
    var texture = new THREE.CanvasTexture(canvas);
    texture.needsUpdate = true;
    
    var spriteMaterial = new THREE.SpriteMaterial({ map: texture, transparent: true, depthTest: false });
    var sprite = new THREE.Sprite(spriteMaterial);
    var scaleRatio = canvas.width / canvas.height;
    sprite.scale.set(scaleRatio * 3, 3, 1);
    return sprite;
}

function createNode(label, type, position, extraOptions) {
    extraOptions = extraOptions || {};
    var color = nodeColors[type] || 0x4FC3F7;
    var geometry;
    
    if (type === 'class') {
        geometry = new THREE.SphereGeometry(3, 24, 24); // 更高精度
        // 可展开的类用实心，不可展开的用空心圆环
        if (!extraOptions.isExpandable) {
            geometry = new THREE.TorusGeometry(3, 0.8, 16, 32); // 更光滑
        }
    } else if (type === 'instance') {
        geometry = new THREE.OctahedronGeometry(2, 1); // 加平滑
    } else if (type === 'objProp') {
        geometry = new THREE.SphereGeometry(2, 20, 20);
    } else {
        geometry = new THREE.TetrahedronGeometry(2, 1);
    }
    
    // 增强材质：Phong 材质 + 高光效果
    var material = new THREE.MeshPhongMaterial({
        color: color,
        emissive: color,
        emissiveIntensity: 0.3,
        transparent: true,
        opacity: 0.9,
        shininess: 80, // 高光
        specular: 0x444444 // 高光颜色
    });
    
    var mesh = new THREE.Mesh(geometry, material);
    mesh.position.copy(position);
    mesh.userData = { 
        label: label, 
        type: type, 
        position: position.clone(),
        id: extraOptions.classId || '',
        isExpandable: !!extraOptions.isExpandable,
        baseEmissive: 0.3 // 记录基础发光强度
    };
    
    // 添加半透明光晕效果（只对类节点）
    if (type === 'class' && !extraOptions.isLeafInHideMode) {
        var glowGeometry = new THREE.SphereGeometry(4.5, 16, 16);
        var glowMaterial = new THREE.MeshBasicMaterial({
            color: color,
            transparent: true,
            opacity: 0.08,
            side: THREE.BackSide // 内面渲染，产生光晕
        });
        var glow = new THREE.Mesh(glowGeometry, glowMaterial);
        mesh.add(glow);
    }
    
    // 标签精灵（在节点上方）
    var fontSize = type === 'instance' ? 20 : 24;
    var labelSprite = createLabel(label, fontSize);
    labelSprite.position.set(0, type === 'class' ? 6 : 4, 0);
    mesh.add(labelSprite);
    
    // 可展开的类添加展开/折叠指示器
    if (type === 'class' && extraOptions.isExpandable) {
        var clsData = ontologyData.classes[extraOptions.classId];
        var indicatorSymbol = (clsData && clsData.isExpanded) ? '▼' : '▶';
        var indicator = createLabel(indicatorSymbol, 16);
        indicator.position.set(0, -5, 0);
        indicator.scale.set(2, 1, 1);
        mesh.add(indicator);
    }
    
    // 隐藏模式下的叶子类添加显示指示器
    if (type === 'class' && extraOptions.isLeafInHideMode) {
        var indicator = createLabel('⊕', 16);  // 加号表示可显示
        indicator.position.set(0, -5, 0);
        indicator.scale.set(2, 1, 1);
        mesh.add(indicator);
    }
    
    return mesh;
}

function createEdge(start, end, label) {
    // 计算中点和高度，生成弧形
    var mid = new THREE.Vector3().addVectors(start, end).multiplyScalar(0.5);
    var distance = start.distanceTo(end);
    
    // 弧线高度：距离越远弧线越高
    var arcHeight = Math.max(distance * 0.15, 5);
    
    // 偏移中点产生弧形（向上偏移）
    mid.y += arcHeight;
    
    // 创建贝塞尔曲线控制点
    var points = [
        start.clone(),
        mid.clone(),
        end.clone()
    ];
    
    var curve = new THREE.CubicBezierCurve3(
        start,
        new THREE.Vector3().lerpVectors(start, mid, 0.5),
        new THREE.Vector3().lerpVectors(mid, end, 0.5),
        end
    );
    
    // 生成弧线上的多个点
    var curvePoints = curve.getPoints(20);
    var geometry = new THREE.BufferGeometry().setFromPoints(curvePoints);
    
    // 弧线与直线的样式区分
    var isClassEdge = label === 'subClassOf';
    var material = new THREE.LineBasicMaterial({
        color: isClassEdge ? 0x4FC3F7 : 0x666688,
        transparent: true,
        opacity: isClassEdge ? 0.4 : 0.25,
        linewidth: 1
    });
    
    var line = new THREE.Line(geometry, material);
    line.userData = { label: label };
    return line;
}

function stringifyNode(node) {
    if (node.termType === 'NamedNode') return node.value;
    if (node.termType === 'BlankNode') return '_' + node.value;
    if (node.termType === 'Literal') return node.value;
    if (node.termType === 'DefaultGraph') return '';
    return String(node);
}

function getLocalName(uri) {
    if (!uri) return '';
    // 移除可能的冒号前缀
    if (uri.startsWith(':')) {
        uri = uri.substring(1);
    }
    var parts = uri.split('#');
    if (parts.length > 1) return parts[parts.length - 1];
    parts = uri.split('/');
    return parts[parts.length - 1];
}

function loadOntologyFromText(ttlText, sourceName) {
    console.log('开始解析本体:', sourceName);
    
    if (typeof N3 === 'undefined' || typeof N3.Parser === 'undefined') {
        console.error('N3.js library not loaded!');
        showError('N3.js 库加载失败，请检查网络连接后刷新页面');
        return;
    }
    
    try {
        // 过滤掉 SWRL 规则段落（N3.js 无法解析）
        var ttlToParse = ttlText;
        var rulesIndex = ttlToParse.indexOf('#    Rules');
        if (rulesIndex !== -1) {
            ttlToParse = ttlToParse.substring(0, rulesIndex).trim();
        }
        
        var parser = new N3.Parser();
        var quads = parser.parse(ttlToParse);
        
        ontologyData = { classes: {}, instances: {}, objProps: {}, datProps: {}, edges: [] };
        
        var owlClass = 'http://www.w3.org/2002/07/owl#Class';
        var owlObjectProperty = 'http://www.w3.org/2002/07/owl#ObjectProperty';
        var owlDatatypeProperty = 'http://www.w3.org/2002/07/owl#DatatypeProperty';
        var rdfType = 'http://www.w3.org/1999/02/22-rdf-syntax-ns#type';
        var rdfsLabel = 'http://www.w3.org/2000/01/rdf-schema#label';
        var rdfsComment = 'http://www.w3.org/2000/01/rdf-schema#comment';
        var rdfsSubClassOf = 'http://www.w3.org/2000/01/rdf-schema#subClassOf';
        var rdfsDomain = 'http://www.w3.org/2000/01/rdf-schema#domain';
        var rdfsRange = 'http://www.w3.org/2000/01/rdf-schema#range';
        
        for (var i = 0; i < quads.length; i++) {
            var quad = quads[i];
            var subj = stringifyNode(quad.subject);
            var pred = quad.predicate.value;
            var obj = stringifyNode(quad.object);
            
            if (pred === rdfType) {
                if (obj === owlClass) {
                    ontologyData.classes[subj] = { 
                        id: subj, 
                        label: getLocalName(subj), 
                        type: 'class', 
                        subClasses: [], 
                        superClass: null,
                        depth: -1,  // 深度，-1表示未计算
                        isExpanded: true  // 是否展开
                    };
                } else if (obj === owlObjectProperty) {
                    ontologyData.objProps[subj] = { id: subj, label: getLocalName(subj), domain: '', range: '', objType: obj };
                } else if (obj === owlDatatypeProperty) {
                    ontologyData.datProps[subj] = { id: subj, label: getLocalName(subj), domain: '', range: '', objType: obj };
                } else {
                    ontologyData.instances[subj] = { id: subj, label: getLocalName(subj), type: obj };
                }
            }
            
            // 提取 rdfs:label（覆盖 URI 本地名称）和 rdfs:comment
            if (pred === rdfsLabel) {
                if (ontologyData.classes[subj]) ontologyData.classes[subj].label = obj;
                else if (ontologyData.instances[subj]) ontologyData.instances[subj].label = obj;
                else if (ontologyData.objProps[subj]) ontologyData.objProps[subj].label = obj;
                else if (ontologyData.datProps[subj]) ontologyData.datProps[subj].label = obj;
            }
            if (pred === rdfsComment) {
                if (ontologyData.classes[subj]) ontologyData.classes[subj].comment = obj;
                else if (ontologyData.instances[subj]) ontologyData.instances[subj].comment = obj;
                else if (ontologyData.objProps[subj]) ontologyData.objProps[subj].comment = obj;
                else if (ontologyData.datProps[subj]) ontologyData.datProps[subj].comment = obj;
            }
        }
        
        for (var j = 0; j < quads.length; j++) {
            var quad2 = quads[j];
            // 跳过 subject 或 object 是空白节点的 quad（如 OWL Restriction）
            if (quad2.subject.termType === 'BlankNode' || quad2.object.termType === 'BlankNode') continue;
            
            var subj2 = stringifyNode(quad2.subject);
            var pred2 = quad2.predicate.value;
            var obj2 = stringifyNode(quad2.object);
            
            if (pred2 === rdfsSubClassOf && ontologyData.classes[subj2]) {
                ontologyData.classes[subj2].superClass = obj2;
                if (!ontologyData.classes[obj2]) {
                    ontologyData.classes[obj2] = { 
                        id: obj2, 
                        label: getLocalName(obj2), 
                        type: 'class', 
                        subClasses: [], 
                        superClass: null,
                        depth: -1,
                        isExpanded: true
                    };
                }
                ontologyData.classes[obj2].subClasses.push(subj2);
            }
            
            if (pred2 === rdfsDomain && ontologyData.objProps[subj2]) {
                ontologyData.objProps[subj2].domain = obj2;
            }
            if (pred2 === rdfsRange && ontologyData.objProps[subj2]) {
                ontologyData.objProps[subj2].range = obj2;
            }
            if (pred2 === rdfsDomain && ontologyData.datProps[subj2]) {
                ontologyData.datProps[subj2].domain = obj2;
            }
            if (pred2 === rdfsRange && ontologyData.datProps[subj2]) {
                ontologyData.datProps[subj2].range = obj2;
            }
        }
        
        console.log('解析完成: ' + Object.keys(ontologyData.classes).length + ' 类, ' + 
                   Object.keys(ontologyData.instances).length + ' 实例, ' + 
                   Object.keys(ontologyData.objProps).length + ' 对象属性, ' + 
                   Object.keys(ontologyData.datProps).length + ' 数据属性');
        
        // 计算类层次深度
        computeClassDepths();
        
        updateStats();
        renderGraph();
        
        document.getElementById('loading-overlay').classList.add('hidden');
        document.getElementById('status-bar').textContent = '已加载: ' + sourceName;
    } catch (error) {
        console.error('解析失败:', error);
        showError('TTL 解析失败: ' + error.message);
    }
}

// 计算类层次深度
function computeClassDepths() {
    var classes = Object.keys(ontologyData.classes);
    
    // 找到根类（没有父类或父类不在本本体中）
    var roots = [];
    for (var c = 0; c < classes.length; c++) {
        var cls = ontologyData.classes[classes[c]];
        if (!cls.superClass || !ontologyData.classes[cls.superClass]) {
            roots.push(classes[c]);
            cls.depth = 0;
        }
    }
    
    // BFS 计算深度
    var queue = roots.slice();
    var visited = {};
    for (var r = 0; r < roots.length; r++) visited[roots[r]] = true;
    
    while (queue.length > 0) {
        var current = queue.shift();
        var currentClass = ontologyData.classes[current];
        if (!currentClass) continue;
        
        for (var i = 0; i < currentClass.subClasses.length; i++) {
            var child = currentClass.subClasses[i];
            if (!visited[child]) {
                visited[child] = true;
                ontologyData.classes[child].depth = currentClass.depth + 1;
                queue.push(child);
            }
        }
    }
    
    // 处理不在任何树中的孤立类
    for (var u = 0; u < classes.length; u++) {
        if (ontologyData.classes[classes[u]].depth < 0) {
            ontologyData.classes[classes[u]].depth = 0;
        }
    }
}

// 检查某个类是否可见（根据展开状态和叶子类隐藏模式）
function isClassVisible(classId) {
    var cls = ontologyData.classes[classId];
    if (!cls) return false;
    
    // 搜索过滤：如果有关键词，类名或URI必须匹配
    if (searchQuery) {
        var displayLabel = cls.label || getLocalName(classId);
        var matchLabel = displayLabel.toLowerCase().indexOf(searchQuery) !== -1;
        var matchId = classId.toLowerCase().indexOf(searchQuery) !== -1;
        if (!matchLabel && !matchId) return false;
        
        // 搜索匹配的类始终可见，且其祖先路径也展开
        var parent = cls.superClass;
        while (parent) {
            if (ontologyData.classes[parent]) {
                ontologyData.classes[parent].isExpanded = true;
            }
            parent = ontologyData.classes[parent] ? ontologyData.classes[parent].superClass : null;
        }
        return true;
    }
    
    // 叶子类模式：如果启用了隐藏叶子类，且该类没有子类，且未被点击显示，则隐藏
    if (hideLeavesMode && (!cls.subClasses || cls.subClasses.length === 0)) {
        if (cls.isHidden !== true) return false;  // 未主动显示的叶子类隐藏
    }
    
    // 根类始终可见
    if (cls.depth <= 2) return true;
    
    // 超过默认3层，检查父类是否展开
    var parent = cls.superClass;
    while (parent) {
        var parentCls = ontologyData.classes[parent];
        if (!parentCls || parentCls.isExpanded) {
            return true;  // 路径上所有父类都展开
        }
        parent = parentCls.superClass;
    }
    return false;
}

// 切换类的展开/折叠状态
function toggleClassExpand(classId) {
    var cls = ontologyData.classes[classId];
    if (!cls) return;
    
    if (cls.subClasses && cls.subClasses.length > 0) {
        // 有子类：展开/折叠
        cls.isExpanded = !cls.isExpanded;
        console.log('类 "' + cls.label + '" ' + (cls.isExpanded ? '已展开' : '已折叠') + '，包含 ' + cls.subClasses.length + ' 个子类');
    } else {
        // 叶子类：切换隐藏/显示
        cls.isHidden = !cls.isHidden;
        console.log('类 "' + cls.label + '" ' + (cls.isHidden ? '已隐藏' : '已显示'));
    }
    renderGraph();
}

// 切换隐藏/显示叶子类模式
function toggleHideLeaves() {
    hideLeavesMode = !hideLeavesMode;
    var btn = document.getElementById('btn-hide-leaves');
    if (hideLeavesMode) {
        btn.classList.add('active');
        btn.textContent = '显示所有类';
    } else {
        btn.classList.remove('active');
        btn.textContent = '隐藏叶子类';
    }
    renderGraph();
}

// 双击切换中心点：以该类为根重新计算深度并渲染
var currentCenterNodeId = null;
function handleDoubleClick(mesh) {
    if (!mesh || !mesh.userData.id || !ontologyData.classes[mesh.userData.id]) return;
    
    var centerNodeId = mesh.userData.id;
    var centerClass = ontologyData.classes[centerNodeId];
    
    console.log('双击切换中心点:', centerClass.label);
    currentCenterNodeId = centerNodeId;
    
    // 展示类的详细信息
    showDetail(mesh);
    
    // 重置所有类的展开状态
    var classes = Object.keys(ontologyData.classes);
    for (var i = 0; i < classes.length; i++) {
        ontologyData.classes[classes[i]].isExpanded = true;
    }
    
    // 以该类为根重新计算深度
    recomputeDepthsFromCenter(centerNodeId);
    
    // 重新渲染
    renderGraph();
    
    // 相机聚焦到该类节点
    focusCameraOnNode(mesh);
}

// 以指定节点为中心重新计算所有类的深度
function recomputeDepthsFromCenter(centerNodeId) {
    var classes = Object.keys(ontologyData.classes);
    
    // 找到所有从该中心点可达的节点（BFS）
    var reachable = {};
    var queue = [centerNodeId];
    reachable[centerNodeId] = true;
    ontologyData.classes[centerNodeId].depth = 0;
    
    while (queue.length > 0) {
        var current = queue.shift();
        var currentClass = ontologyData.classes[current];
        if (!currentClass) continue;
        
        // 子类（子类）
        if (currentClass.subClasses) {
            for (var i = 0; i < currentClass.subClasses.length; i++) {
                var child = currentClass.subClasses[i];
                if (!reachable[child]) {
                    reachable[child] = true;
                    ontologyData.classes[child].depth = currentClass.depth + 1;
                    queue.push(child);
                }
            }
        }
        
        // 父类（superClass）
        if (currentClass.superClass && ontologyData.classes[currentClass.superClass]) {
            var parent = currentClass.superClass;
            if (!reachable[parent]) {
                reachable[parent] = true;
                ontologyData.classes[parent].depth = currentClass.depth + 1;
                queue.push(parent);
            }
        }
    }
    
    // 不可达的孤立类设为深度1（全部可见）
    for (var j = 0; j < classes.length; j++) {
        if (!reachable[classes[j]]) {
            ontologyData.classes[classes[j]].depth = 1;
        }
    }
}

function updateStats() {
    document.getElementById('stat-classes').textContent = Object.keys(ontologyData.classes).length;
    document.getElementById('stat-instances').textContent = Object.keys(ontologyData.instances).length;
    document.getElementById('stat-objprops').textContent = Object.keys(ontologyData.objProps).length;
    document.getElementById('stat-dataprops').textContent = Object.keys(ontologyData.datProps).length;
}

// 更新图例：显示有多少类有隐藏的未展开子类
function updateLegend() {
    var classes = Object.keys(ontologyData.classes);
    var hiddenExpandable = 0;
    for (var i = 0; i < classes.length; i++) {
        var classId = classes[i];
        var cls = ontologyData.classes[classId];
        if (cls.subClasses && cls.subClasses.length > 0) {
            // 检查是否有隐藏的子类
            for (var j = 0; j < cls.subClasses.length; j++) {
                if (!isClassVisible(cls.subClasses[j])) {
                    hiddenExpandable++;
                    break;
                }
            }
        }
    }
    var legendEl = document.getElementById('legend-hidden-classes');
    if (legendEl) {
        if (hiddenExpandable > 0) {
            legendEl.innerHTML = '⚠️ ' + hiddenExpandable + ' 个类有隐藏子类（点击展开）';
        } else {
            legendEl.innerHTML = '';
        }
    }
}

var renderState = {
    _nodesBatch: [],
    _edgesBatch: [],
    _currentNodeIdx: 0,
    _currentEdgeIdx: 0,
    _nodeBatchSize: 50,
    _edgeBatchSize: 100,
    _isRendering: false,
    _onRenderComplete: null
};

function renderGraph() {
    // 清理旧节点
    for (var k = 0; k < nodeObjects.length; k++) scene.remove(nodeObjects[k]);
    for (var m = 0; m < edgeObjects.length; m++) scene.remove(edgeObjects[m]);
    nodeObjects = [];
    edgeObjects = [];
    
    var classes = Object.keys(ontologyData.classes);
    var instances = Object.keys(ontologyData.instances);
    var objProps = Object.keys(ontologyData.objProps);
    var datProps = Object.keys(ontologyData.datProps);
    
    // 大文件限制实例数量，避免渲染阻塞
    var maxInstances = 500;
    var actualInstances = instances;
    if (instances.length > maxInstances) {
        actualInstances = instances.slice(0, maxInstances);
        console.warn('实例数量过多 (' + instances.length + ')，只显示前 ' + maxInstances + ' 个');
    }
    
    var positions = {};
    var classPositions = computeLayout(classes);
    for (var key in classPositions) {
        positions[key] = classPositions[key];
    }
    
    var instanceId = 0;
    for (var instIdx = 0; instIdx < actualInstances.length; instIdx++) {
        var inst = ontologyData.instances[actualInstances[instIdx]];
        var type = inst.type;
        if (positions[type]) {
            var offset = (instanceId % 6 - 3) * 10;
            positions[actualInstances[instIdx]] = new THREE.Vector3(
                positions[type].x + offset,
                positions[type].y + 15 + Math.floor(instanceId / 6) * 15,
                positions[type].z + ((instanceId % 6) * 5 - 12)
            );
        } else {
            positions[actualInstances[instIdx]] = new THREE.Vector3((instanceId % 8 - 4) * 25, 20, (Math.floor(instanceId / 8) - 3) * 25);
        }
        instanceId++;
    }
    
    var propId = 0;
    for (var propIdx = 0; propIdx < objProps.length; propIdx++) {
        var prop = ontologyData.objProps[objProps[propIdx]];
        var pos;
        if (positions[prop.domain] && positions[prop.range]) {
            pos = new THREE.Vector3(
                (positions[prop.domain].x + positions[prop.range].x) / 2,
                (positions[prop.domain].y + positions[prop.range].y) / 2 + 15,
                (positions[prop.domain].z + positions[prop.range].z) / 2
            );
        } else {
            pos = new THREE.Vector3((propId % 6 - 3) * 30, 40, (Math.floor(propId / 6) - 2) * 30);
        }
        positions[objProps[propIdx]] = pos;
        propId++;
    }
    
    var dpId = 0;
    for (var dpIdx = 0; dpIdx < datProps.length; dpIdx++) {
        var dp = ontologyData.datProps[datProps[dpIdx]];
        var pos2;
        if (positions[dp.domain]) {
            pos2 = new THREE.Vector3(
                positions[dp.domain].x + 20,
                positions[dp.domain].y + 10,
                positions[dp.domain].z
            );
        } else {
            pos2 = new THREE.Vector3((dpId % 4 - 2) * 35, 55, (Math.floor(dpId / 4) - 1) * 35);
        }
        positions[datProps[dpIdx]] = pos2;
        dpId++;
    }
    
    // 构建节点批次
    renderState._nodesBatch = [];
    renderState._currentNodeIdx = 0;
    
    var totalNodeCount = 0;
    
    if (currentMode !== 'classes' || currentMode === 'classes') {
        for (var cIdx = 0; cIdx < classes.length; cIdx++) {
            var classId = classes[cIdx];
            var cls = ontologyData.classes[classId];
            // 根据深度和展开状态过滤类
            if (!isClassVisible(classId)) continue;
            if (positions[classId]) {
                var isExpandable = cls.subClasses && cls.subClasses.length > 0;
                // 叶子类在 hideLeavesMode 下也要渲染，并标记为可点击切换显示
                var isLeafInHideMode = hideLeavesMode && !isExpandable && !cls.isHidden;
                renderState._nodesBatch.push({
                    label: cls.label,
                    type: 'class',
                    position: positions[classId],
                    classId: classId,
                    isExpandable: isExpandable,
                    isLeafInHideMode: isLeafInHideMode
                });
                totalNodeCount++;
            }
        }
    }
    
    if (showInstances && currentMode === 'full') {
        for (var iIdx = 0; iIdx < actualInstances.length; iIdx++) {
            var inst = ontologyData.instances[actualInstances[iIdx]];
            var instType = inst.type;
            // 只渲染所属类可见的实例
            if (!isClassVisible(instType)) continue;
            if (positions[actualInstances[iIdx]]) {
                renderState._nodesBatch.push({
                    label: inst.label,
                    type: 'instance',
                    position: positions[actualInstances[iIdx]]
                });
                totalNodeCount++;
            }
        }
    }
    
    if (currentMode === 'full' || currentMode === 'props') {
        for (var pIdx = 0; pIdx < objProps.length; pIdx++) {
            var op = ontologyData.objProps[objProps[pIdx]];
            // 只渲染定义域和值域都可见的属性
            if (op.domain && !isClassVisible(op.domain)) continue;
            if (op.range && !isClassVisible(op.range)) continue;
            if (positions[objProps[pIdx]]) {
                renderState._nodesBatch.push({
                    label: op.label,
                    type: 'objProp',
                    position: positions[objProps[pIdx]]
                });
                totalNodeCount++;
            }
        }
    }
    
    if (showDataProps && currentMode === 'full') {
        for (var dIdx = 0; dIdx < datProps.length; dIdx++) {
            var dp = ontologyData.datProps[datProps[dIdx]];
            // 只渲染定义域可见的数据属性
            if (dp.domain && !isClassVisible(dp.domain)) continue;
            if (positions[datProps[dIdx]]) {
                renderState._nodesBatch.push({
                    label: dp.label,
                    type: 'datProp',
                    position: positions[datProps[dIdx]]
                });
                totalNodeCount++;
            }
        }
    }
    
    // 构建边批次
    renderState._edgesBatch = [];
    renderState._currentEdgeIdx = 0;
    var totalEdgeCount = 0;
    
    for (var scIdx = 0; scIdx < classes.length; scIdx++) {
        var cls = ontologyData.classes[classes[scIdx]];
        // 边的两端类都必须可见
        if (!isClassVisible(classes[scIdx])) continue;
        
        if (cls.superClass && isClassVisible(cls.superClass) && positions[cls.superClass] && positions[classes[scIdx]]) {
            renderState._edgesBatch.push({
                start: positions[cls.superClass],
                end: positions[classes[scIdx]],
                label: 'subClassOf'
            });
            totalEdgeCount++;
        }
        for (var childIdx = 0; childIdx < cls.subClasses.length; childIdx++) {
            var childId = cls.subClasses[childIdx];
            if (isClassVisible(childId) && positions[classes[scIdx]] && positions[childId]) {
                renderState._edgesBatch.push({
                    start: positions[childId],
                    end: positions[classes[scIdx]],
                    label: 'subClassOf'
                });
                totalEdgeCount++;
            }
        }
    }
    
    for (var opIdx = 0; opIdx < objProps.length; opIdx++) {
        var op = ontologyData.objProps[objProps[opIdx]];
        // 属性节点可见才渲染边
        var isPropVisible = isClassVisible(op.domain) || isClassVisible(op.range);
        if (!isPropVisible) continue;
        
        if (op.domain && positions[op.domain] && positions[objProps[opIdx]]) {
            renderState._edgesBatch.push({
                start: positions[op.domain],
                end: positions[objProps[opIdx]],
                label: 'domain'
            });
            totalEdgeCount++;
        }
        if (op.range && positions[op.range] && positions[objProps[opIdx]]) {
            renderState._edgesBatch.push({
                start: positions[objProps[opIdx]],
                end: positions[op.range],
                label: 'range'
            });
            totalEdgeCount++;
        }
    }
    
    // 更新加载提示
    var statusEl = document.getElementById('status-bar');
    var loadingEl = document.getElementById('loading-overlay');
    if (totalNodeCount + totalEdgeCount > 100) {
        if (!loadingEl.classList.contains('hidden')) {
            document.getElementById('loading-text').textContent = '正在渲染 ' + totalNodeCount + ' 个节点...';
        }
    }
    
    // 分批渲染节点
    renderBatchedNodes();
}

function renderBatchedNodes() {
    if (renderState._currentNodeIdx >= renderState._nodesBatch.length) {
        // 节点渲染完成，开始渲染边
        renderBatchedEdges();
        return;
    }
    
    var endIdx = Math.min(
        renderState._currentNodeIdx + renderState._nodeBatchSize,
        renderState._nodesBatch.length
    );
    
    for (var i = renderState._currentNodeIdx; i < endIdx; i++) {
        var item = renderState._nodesBatch[i];
        var extraOptions = {
            classId: item.classId || '',
            isExpandable: !!item.isExpandable,
            isLeafInHideMode: !!item.isLeafInHideMode
        };
        var node = createNode(item.label, item.type, item.position, extraOptions);
        scene.add(node);
        nodeObjects.push(node);
    }
    
    renderState._currentNodeIdx = endIdx;
    
    // 更新进度
    if (renderState._nodesBatch.length > 50) {
        var loadingEl = document.getElementById('loading-overlay');
        if (loadingEl && !loadingEl.classList.contains('hidden')) {
            var progress = Math.round((renderState._currentNodeIdx / renderState._nodesBatch.length) * 100);
            document.getElementById('loading-text').textContent = '渲染节点 ' + progress + '% (' + renderState._currentNodeIdx + '/' + renderState._nodesBatch.length + ')';
        }
    }
    
    // 用 requestAnimationFrame 继续下一批
    requestAnimationFrame(function() {
        renderBatchedNodes();
    });
}

function renderBatchedEdges() {
    if (renderState._currentEdgeIdx >= renderState._edgesBatch.length) {
        // 全部完成
        var loadingEl = document.getElementById('loading-overlay');
        if (loadingEl) loadingEl.classList.add('hidden');
        document.getElementById('status-bar').textContent = '已加载: ' + (renderState._renderedSourceName || '');
        if (renderState._onRenderComplete) {
            renderState._onRenderComplete();
        }
        // 更新图例显示
        updateLegend();
        return;
    }
    
    var endIdx = Math.min(
        renderState._currentEdgeIdx + renderState._edgeBatchSize,
        renderState._edgesBatch.length
    );
    
    for (var i = renderState._currentEdgeIdx; i < endIdx; i++) {
        var item = renderState._edgesBatch[i];
        var edge = createEdge(item.start, item.end, item.label);
        scene.add(edge);
        edgeObjects.push(edge);
    }
    
    renderState._currentEdgeIdx = endIdx;
    
    // 用 requestAnimationFrame 继续下一批
    requestAnimationFrame(function() {
        renderBatchedEdges();
    });
}

function computeLayout(classes) {
    var positions = {};
    var roots = [];
    var others = [];
    
    for (var c = 0; c < classes.length; c++) {
        var cls = ontologyData.classes[classes[c]];
        if (!cls.superClass || !ontologyData.classes[cls.superClass]) {
            roots.push(classes[c]);
        } else {
            others.push(classes[c]);
        }
    }
    
    // ========== 3D 球形分层布局 ==========
    // 根类在球心，每层按深度均匀分布在球面上
    
    // 按深度分组
    var depthGroups = {};
    var allClassIds = classes.slice();
    for (var i = 0; i < allClassIds.length; i++) {
        var depth = ontologyData.classes[allClassIds[i]].depth;
        if (!depthGroups[depth]) depthGroups[depth] = [];
        depthGroups[depth].push(allClassIds[i]);
    }
    
    var maxDepth = 0;
    for (var d in depthGroups) {
        var num = parseInt(d);
        if (num > maxDepth) maxDepth = num;
    }
    
    // 根类 (depth=0) 放在球心
    for (var r = 0; r < roots.length; r++) {
        if (roots[r] && !positions[roots[r]]) {
            positions[roots[r]] = new THREE.Vector3(0, 0, 0);
        }
    }
    
    // 其他层级：按球面均匀分布
    for (var depth = 1; depth <= maxDepth; depth++) {
        var group = depthGroups[depth];
        if (!group || group.length === 0) continue;
        
        // 球壳半径随深度递增
        var shellRadius = depth * 65;
        
        // 使用 Fibonacci Sphere 算法在球面上均匀分布节点
        var goldenAngle = Math.PI * (3 - Math.sqrt(5)); // ~2.39996
        
        for (var i = 0; i < group.length; i++) {
            var y = 1 - (i / (group.length - 1 || 1)) * 2; // -1 to 1
            var radiusAtY = Math.sqrt(1 - y * y);
            var theta = goldenAngle * i;
            
            var x = Math.cos(theta) * radiusAtY;
            var z = Math.sin(theta) * radiusAtY;
            
            positions[group[i]] = new THREE.Vector3(x * shellRadius, y * shellRadius, z * shellRadius);
        }
    }
    
    // 孤立类（不在任何树中）：放在外围球面上
    for (var oIdx = 0; oIdx < others.length; oIdx++) {
        if (!positions[others[oIdx]]) {
            var angle = (oIdx / Math.max(others.length, 1)) * Math.PI * 2;
            var shellR = (maxDepth + 1) * 65 + oIdx * 15;
            positions[others[oIdx]] = new THREE.Vector3(
                Math.cos(angle) * shellR,
                (oIdx % 3 - 1) * 30,
                Math.sin(angle) * shellR
            );
        }
    }
    
    return positions;
}

function setMode(mode) {
    currentMode = mode;
    var buttons = document.querySelectorAll('.btn[data-mode]');
    for (var b = 0; b < buttons.length; b++) {
        buttons[b].classList.remove('active');
    }
    var activeBtn = document.querySelector('.btn[data-mode="' + mode + '"]');
    if (activeBtn) activeBtn.classList.add('active');
    renderGraph();
}

function toggleInstances() {
    showInstances = !showInstances;
    document.getElementById('btn-instances').classList.toggle('active');
    renderGraph();
}

function toggleDataProps() {
    showDataProps = !showDataProps;
    document.getElementById('btn-dataprops').classList.toggle('active');
    renderGraph();
}


// 加载文件列表
function loadFileList() {
    fetch('./files.json')
        .then(function(response) {
            if (!response.ok) throw new Error('HTTP ' + response.status);
            return response.json();
        })
        .then(function(data) {
            var sel = document.getElementById('file-select');
            sel.innerHTML = '<option value="">-- 选择文件 --</option>';
            if (data.files) {
                data.files.forEach(function(f, idx) {
                    var opt = document.createElement('option');
                    opt.value = f.name;
                    opt.textContent = f.name + ' (' + (f.size / 1024).toFixed(1) + ' KB)';
                    sel.appendChild(opt);
                });
                // 默认选中并加载第一个文件（FRM）
                if (data.files.length > 0) {
                    sel.value = data.files[0].name;
                    handleFileSelect({target: sel});
                }
            }
        })
        .catch(function(err) {
            console.warn('无法加载文件列表:', err.message);
            document.getElementById('file-select').innerHTML = '<option value="">-- 无法加载文件列表 --</option>';
        });
}

// 从下拉框选择文件
function handleFileSelect(event) {
    var filename = event.target.value;
    if (!filename) return;
    var path = './' + encodeURIComponent(filename);
    document.getElementById('loading-overlay').classList.remove('hidden');
    document.getElementById('loading-text').textContent = '正在加载: ' + filename;
    
    fetch(path)
        .then(function(response) {
            if (!response.ok) throw new Error('HTTP ' + response.status);
            return response.text();
        })
        .then(function(text) {
            loadOntologyFromText(text, filename);
        })
        .catch(function(err) {
            console.error('加载文件失败:', err.message);
            document.getElementById('loading-text').textContent = '加载失败: ' + err.message;
            document.getElementById('loading-overlay').classList.add('hidden');
        });
}

function handleFileUpload(event) {
    var file = event.target.files[0];
    if (!file) return;
    
    var reader = new FileReader();
    reader.onload = function(e) {
        loadOntologyFromText(e.target.result, file.name);
    };
    reader.readAsText(file);
}

function showDetail(mesh) {
    var panel = document.getElementById('detail-panel');
    var data = mesh.userData;
    
    document.getElementById('detail-title').textContent = data.label;
    
    var html = '<div class="prop"><span>类型:</span> ' + data.type + '</div>';
    if (data.type === 'class') {
        var cls = ontologyData.classes[data.id];
        if (cls) {
            if (cls.superClass) html += '<div class="prop"><span>父类:</span> ' + getLocalName(cls.superClass) + '</div>';
            html += '<div class="prop"><span>子类数:</span> ' + cls.subClasses.length + '</div>';
            if (cls.comment) html += '<div class="prop"><span>说明:</span> ' + cls.comment + '</div>';
        }
    } else if (data.type === 'objProp') {
        var prop = ontologyData.objProps[data.id];
        if (prop) {
            if (prop.domain) html += '<div class="prop"><span>定义域:</span> ' + getLocalName(prop.domain) + '</div>';
            if (prop.range) html += '<div class="prop"><span>值域:</span> ' + getLocalName(prop.range) + '</div>';
            if (prop.comment) html += '<div class="prop"><span>说明:</span> ' + prop.comment + '</div>';
        }
    } else if (data.type === 'datProp') {
        var dp = ontologyData.datProps[data.id];
        if (dp) {
            if (dp.domain) html += '<div class="prop"><span>定义域:</span> ' + getLocalName(dp.domain) + '</div>';
            if (dp.comment) html += '<div class="prop"><span>说明:</span> ' + dp.comment + '</div>';
        }
    } else if (data.type === 'instance') {
        var inst = ontologyData.instances[data.id];
        if (inst && inst.type) html += '<div class="prop"><span>类型:</span> ' + getLocalName(inst.type) + '</div>';
    }
    
    document.getElementById('detail-content').innerHTML = html;
    panel.style.display = 'block';
}

function closeDetail() {
    document.getElementById('detail-panel').style.display = 'none';
}

function exportPNG() {
    renderer.render(scene, camera);
    var link = document.createElement('a');
    link.download = 'ontology-graph.png';
    link.href = renderer.domElement.toDataURL('image/png');
    link.click();
}

function showError(message) {
    var errorDiv = document.getElementById('error-message');
    document.getElementById('error-text').innerHTML = message;
    errorDiv.style.display = 'block';
}

function hideError() {
    document.getElementById('error-message').style.display = 'none';
}

initThree();

// 页面加载后初始化文件列表和图形
loadFileList();

// 切换label/uri显示
function toggleLabelSource() {
    if (labelSourceType === 'label') {
        labelSourceType = 'uri';
        document.getElementById('btn-label-toggle').textContent = '显示: URI';
    } else {
        labelSourceType = 'label';
        document.getElementById('btn-label-toggle').textContent = '显示: Label';
    }
    renderGraph();
}

// 搜索节点
function handleSearch(event) {
    searchQuery = event.target.value.trim().toLowerCase();
    renderGraph();
}

// 获取节点显示名称
function getNodeDisplayLabel(item) {
    if (labelSourceType === 'uri') {
        return item.id;
    }
    return item.label;
}
</script>

</body>
</html>
