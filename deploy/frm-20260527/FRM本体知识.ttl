  rdfs:comment "Discount applied during fire sale"@en, "火线出售时的折扣率"@zh .

# --- Hedging Strategies (第1章补充) ---
:hasHedgeRatio a owl:DatatypeProperty ;
  rdfs:domain :HedgeInstrument ;
  rdfs:range xsd:decimal ;
  rdfs:label "has hedge ratio"@en, "对冲比率"@zh ;
  rdfs:comment "Optimal hedge ratio"@en, "最佳对冲比率"@zh .

:hasBasis a owl:DatatypeProperty ;
  rdfs:domain :HedgeInstrument ;
  rdfs:range xsd:decimal ;
  rdfs:label "has basis"@en, "基差"@zh ;
  rdfs:comment "Basis = Spot price - Futures price"@en, "基差=现货价格-期货价格"@zh .

:hasCostOfHedge a owl:DatatypeProperty ;
  rdfs:domain :HedgingCost ;
  rdfs:range xsd:decimal ;
  rdfs:label "has hedging cost value"@en, "对冲成本值"@zh ;
  rdfs:comment "Total cost of hedging strategy"@en, "对冲策略的总成本"@zh .

:hasEffectivenessRatio a owl:DatatypeProperty ;
