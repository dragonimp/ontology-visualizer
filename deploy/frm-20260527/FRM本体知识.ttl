  rdfs:range xsd:decimal ;
  rdfs:label "has effectiveness ratio"@en, "有效性比率"@zh ;
  rdfs:comment "Percentage of risk offset by hedge"@en, "对冲抵消风险的百分比"@zh .

# --- Moody's Rating (补充) ---
:hasCreditRating a owl:DatatypeProperty ;
  rdfs:domain :CreditRisk ;
  rdfs:range xsd:string ;
  rdfs:label "has credit rating"@en, "信用评级"@zh ;
  rdfs:comment "Credit rating from rating agencies"@en, "评级机构的信用评级"@zh .

:hasSpreadOverBenchmark a owl:DatatypeProperty ;
  rdfs:domain :CreditRisk ;
  rdfs:range xsd:decimal ;
  rdfs:label "has spread over benchmark"@en, "基准利差"@zh ;
  rdfs:comment "Credit spread over benchmark rate"@en, "相对基准的信用利差"@zh .

# --- Liquidity Metrics (第5章补充) ---
:hasBidAskSpread a owl:DatatypeProperty ;
  rdfs:domain :LiquidityRisk ;
  rdfs:range xsd:decimal ;
  rdfs:label "has bid-ask spread"@en, "买卖价差"@zh ;
  rdfs:comment "Bid-ask spread percentage"@en, "买卖价差百分比"@zh .

:hasMarketDepth a owl:DatatypeProperty ;
  rdfs:domain :LiquidityRisk ;
  rdfs:range xsd:decimal ;
  rdfs:label "has market depth"@en, "市场深度"@zh ;
  rdfs:comment "Volume available at best bid/ask"@en, "最佳买卖价位的可用量"@zh .

:hasTimeToLiquidate a owl:DatatypeProperty ;
  rdfs:domain :LiquidityRisk ;
  rdfs:range xsd:decimal ;
  rdfs:label "has time to liquidate"@en, "变现时间"@zh ;
  rdfs:comment "Time needed to liquidate position"@en, "变现所需时间"@zh .

:hasHaircut a owl:DatatypeProperty ;
  rdfs:domain :LiquidityCoverageRatio ;
  rdfs:range xsd:decimal ;
  rdfs:label "has haircut"@en, "折价率"@zh ;
  rdfs:comment "Haircut applied to collateral"@en, "抵押品折价率"@zh .

# --- Stress Testing (第5章补充) ---
:hasStressScenarioSeverity a owl:DatatypeProperty ;
  rdfs:domain :StressTesting ;
  rdfs:range xsd:decimal ;
  rdfs:label "has scenario severity"@en, "情景严重程度"@zh ;
  rdfs:comment "Severity level of stress scenario"@en, "压力情景严重程度级别"@zh .

:hasCapitalDeviation a owl:DatatypeProperty ;
  rdfs:domain :StressTesting ;
  rdfs:range xsd:decimal ;
  rdfs:label "has capital deviation"@en, "资本偏离"@zh ;
  rdfs:comment "Deviation from minimum capital under stress"@en, "压力情景下资本偏离最小要求值"@zh .

# --- Operational Risk Metrics ---
:hasLossFrequency a owl:DatatypeProperty ;
  rdfs:domain :OperationalRisk ;
  rdfs:range xsd:decimal ;
  rdfs:label "has loss frequency"@en, "损失频率"@zh ;
  rdfs:comment "Frequency of operational loss events"@en, "操作风险损失事件频率"@zh .

:hasSeverityLevel a owl:DatatypeProperty ;
  rdfs:domain :OperationalRisk ;
  rdfs:range xsd:decimal ;
  rdfs:label "has severity level"@en, "严重程度"@zh ;
  rdfs:comment "Average severity of loss events"@en, "损失事件平均严重程度"@zh .

# --- Model Risk ---
:hasModelUncertainty a owl:DatatypeProperty ;
  rdfs:domain :ModelRisk ;
  rdfs:range xsd:decimal ;
  rdfs:label "has model uncertainty"@en, "模型不确定性"@zh ;
  rdfs:comment "Measure of model estimation uncertainty"@en, "模型估计不确定性度量"@zh .

:hasBacktestingBreaches a owl:DatatypeProperty ;
  rdfs:domain :ValueAtRisk ;
  rdfs:range xsd:integer ;
  rdfs:label "has backtesting breaches"@en, "回测突破次数"@zh ;
  rdfs:comment "Number of exceptions in VaR backtesting"@en, "VaR回测中的例外次数"@zh .
