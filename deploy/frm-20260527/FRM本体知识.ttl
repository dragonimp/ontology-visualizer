  rdfs:range xsd:decimal ;
  rdfs:label "has volatility"@en, "波动率"@zh ;
  rdfs:comment "Standard deviation of returns"@en, "收益率的标准差"@zh .

:hasCorrelation a owl:DatatypeProperty ;
  rdfs:domain :RiskType ;
  rdfs:range xsd:decimal ;
  rdfs:label "has correlation"@en, "相关系数"@zh ;
  rdfs:comment "Correlation coefficient between risk factors"@en, "风险因素之间的相关系数"@zh .

:hasExpectedReturn a owl:DatatypeProperty ;
  rdfs:domain :RiskType ;
  rdfs:range xsd:decimal ;
  rdfs:label "has expected return"@en, "期望收益率"@zh ;
  rdfs:comment "Expected return rate"@en, "预期收益率"@zh .

:hasStandardDeviation a owl:DatatypeProperty ;
  rdfs:domain :Portfolio ;
  rdfs:range xsd:decimal ;
  rdfs:label "has standard deviation"@en, "标准差"@zh ;
  rdfs:comment "Portfolio standard deviation"@en, "投资组合标准差"@zh .

:hasBeta a owl:DatatypeProperty ;
  rdfs:domain :PricingModel ;
  rdfs:range xsd:decimal ;
  rdfs:label "has beta"@en, "Beta系数"@zh ;
  rdfs:comment "Systematic risk beta coefficient"@en, "系统性风险Beta系数"@zh .

:hasAlpha a owl:DatatypeProperty ;
  rdfs:domain :PricingModel ;
  rdfs:range xsd:decimal ;
  rdfs:label "has alpha"@en, "Alpha值"@zh ;
  rdfs:comment "Jensen's Alpha or excess return"@en, "詹森阿尔法或超额收益"@zh .

:hasSharpeRatio a owl:DatatypeProperty ;
  rdfs:domain :MeasurementMetric ;
  rdfs:range xsd:decimal ;
  rdfs:label "has Sharpe ratio"@en, "夏普比率值"@zh ;
  rdfs:comment "Sharpe ratio numerical value"@en, "夏普比率数值"@zh .

:hasTreynorRatio a owl:DatatypeProperty ;
  rdfs:domain :MeasurementMetric ;
  rdfs:range xsd:decimal ;
  rdfs:label "has Treynor ratio"@en, "特雷诺比率值"@zh ;
  rdfs:comment "Treynor ratio numerical value"@en, "特雷诺比率数值"@zh .

:hasInformationRatio a owl:DatatypeProperty ;
  rdfs:domain :MeasurementMetric ;
  rdfs:range xsd:decimal ;
  rdfs:label "has information ratio"@en, "信息比率值"@zh ;
  rdfs:comment "Information ratio numerical value"@en, "信息比率数值"@zh .

:hasTrackingError a owl:DatatypeProperty ;
  rdfs:domain :MeasurementMetric ;
  rdfs:range xsd:decimal ;
  rdfs:label "has tracking error"@en, "追踪误差"@zh ;
  rdfs:comment "Active risk / tracking error"@en, "主动风险/追踪误差"@zh .

:hasDrawdown a owl:DatatypeProperty ;
  rdfs:domain :Portfolio ;
  rdfs:range xsd:decimal ;
  rdfs:label "has maximum drawdown"@en, "最大回撤"@zh ;
  rdfs:comment "Maximum drawdown from peak"@en, "从峰值的最大回撤"@zh .

:hasDefaultProbability a owl:DatatypeProperty ;
  rdfs:domain :CreditRisk ;
  rdfs:range xsd:decimal ;
  rdfs:label "has default probability"@en, "违约概率"@zh ;
  rdfs:comment "Probability of default (PD)"@en, "违约概率（PD）"@zh .

:hasLossGivenDefault a owl:DatatypeProperty ;
  rdfs:domain :CreditRisk ;
  rdfs:range xsd:decimal ;
  rdfs:label "has loss given default"@en, "违约损失率"@zh ;
  rdfs:comment "Loss given default (LGD)"@en, "违约损失率（LGD）"@zh .

:hasExposureAtDefault a owl:DatatypeProperty ;
  rdfs:domain :CreditRisk ;
  rdfs:range xsd:decimal ;
  rdfs:label "has exposure at default"@en, "违约风险敞口"@zh ;
  rdfs:comment "Exposure at default (EAD)"@en, "违约风险敞口（EAD）"@zh .

