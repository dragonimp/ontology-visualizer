  rdfs:label "has OpVaR"@en, "操作风险VaR"@zh ;
  rdfs:comment "Operational Value at Risk"@en, "操作风险价值"@zh .

:hasCapitalCharge a owl:DatatypeProperty ;
  rdfs:domain :OperationalRisk ;
  rdfs:range xsd:decimal ;
  rdfs:label "has capital charge"@en, "资本要求"@zh ;
  rdfs:comment "Basel III operational risk capital charge"@en, "巴塞尔III操作风险资本要求"@zh .

:hasFactorLoading a owl:DatatypeProperty ;
  rdfs:domain :APT ;
  rdfs:range xsd:decimal ;
  rdfs:label "has factor loading"@en, "因子载荷"@zh ;
  rdfs:comment "Factor loading in APT model"@en, "APT模型中的因子载荷"@zh .

:hasFactorRiskPremium a owl:DatatypeProperty ;
  rdfs:domain :APT ;
  rdfs:range xsd:decimal ;
  rdfs:label "has factor risk premium"@en, "因子风险溢价"@zh ;
  rdfs:comment "Risk premium for a factor in APT"@en, "APT中某因子的风险溢价"@zh .

# ===== Object Properties =====
:comparedTo a owl:ObjectProperty ;
rdfs:domain :EnterpriseRiskManagement ;
rdfs:range :TraditionalRiskManagement ;
rdfs:label "compared to"@en, "与...对比"@zh .

:hasElement a owl:ObjectProperty ;
rdfs:domain :COSO_Framework ;
rdfs:range :COSO_Framework ;
rdfs:label "has element"@en, "包含要素"@zh .

:correlatesWith a owl:ObjectProperty ;
rdfs:domain :RiskType ;
rdfs:range :RiskType ;
rdfs:label "correlates with"@en, "与...相关"@zh .

:causesContagionTo a owl:ObjectProperty ;
rdfs:domain :FinancialDisaster ;
rdfs:range :CrisisConcept ;
rdfs:label "causes contagion to"@en, "导致传染"@zh .

# ===== Additional Data Properties Part 2 (补充数据属性Part 2) =====

# --- Risk Governance & Culture (第3章) ---
:hasRiskCultureScore a owl:DatatypeProperty ;
  rdfs:domain :GovernanceAndCulture ;
  rdfs:range xsd:decimal ;
  rdfs:label "has risk culture score"@en, "风险文化评分"@zh ;
  rdfs:comment "Score measuring organizational risk culture"@en, "衡量组织风险文化的评分"@zh .

:hasToneAtTop a owl:DatatypeProperty ;
  rdfs:domain :GovernanceAndCulture ;
  rdfs:range xsd:decimal ;
  rdfs:label "has tone at top score"@en, "高层基调评分"@zh ;
  rdfs:comment "Score for tone at top assessment"@en, "高层基调评估评分"@zh .

:hasBoardIndependence a owl:DatatypeProperty ;
  rdfs:domain :GovernanceAndCulture ;
  rdfs:range xsd:decimal ;
  rdfs:label "has board independence"@en, "董事会独立性"@zh ;
  rdfs:comment "Percentage of independent board members"@en, "独立董事比例"@zh .

# --- Risk Appetite & Tolerance (第3章) ---
:hasRiskAppetiteLevel a owl:DatatypeProperty ;
  rdfs:domain :RiskAppetite ;
  rdfs:range xsd:decimal ;
  rdfs:label "has risk appetite level"@en, "风险偏好水平"@zh ;
  rdfs:comment "Numerical level of risk appetite"@en, "风险偏好的数值水平"@zh .

:hasRiskToleranceBand a owl:DatatypeProperty ;
  rdfs:domain :RiskTolerance ;
  rdfs:range xsd:decimal ;
  rdfs:label "has risk tolerance band"@en, "风险容忍度区间"@zh ;
  rdfs:comment "Acceptable deviation band percentage"@en, "可接受波动区间百分比"@zh .

:hasRiskCapacityLimit a owl:DatatypeProperty ;
  rdfs:domain :RiskCapacity ;
  rdfs:range xsd:decimal ;
  rdfs:label "has risk capacity limit"@en, "风险容量上限"@zh ;
  rdfs:comment "Maximum risk capacity in monetary terms"@en, "货币形式的风险容量上限"@zh .

# --- Financial Instruments (第8章) ---
:hasMaturity a owl:DatatypeProperty ;
  rdfs:domain :FinancialInstrument ;
  rdfs:range xsd:decimal ;
  rdfs:label "has maturity"@en, "到期期限"@zh ;
  rdfs:comment "Time to maturity in years"@en, "距到期年数"@zh .

:hasCouponRate a owl:DatatypeProperty ;
  rdfs:domain :FinancialInstrument ;
  rdfs:range xsd:decimal ;
  rdfs:label "has coupon rate"@en, "票息率"@zh ;
  rdfs:comment "Annual coupon rate"@en, "年票息率"@zh .

:hasFaceValue a owl:DatatypeProperty ;
