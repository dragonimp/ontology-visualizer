  rdfs:range xsd:decimal ;
  rdfs:label "has face value"@en, "面值"@zh ;
  rdfs:comment "Face value or par value"@en, "面值或票面价值"@zh .

:hasNotionalAmount a owl:DatatypeProperty ;
