  rdfs:range xsd:decimal ;
  rdfs:label "has duration"@en, "久期"@zh ;
  rdfs:comment "Macaulay or modified duration"@en, "麦考利久期或修正久期"@zh .

:hasConvexity a owl:DatatypeProperty ;
  rdfs:domain :InterestRateRisk ;
