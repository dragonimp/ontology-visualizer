  rdfs:comment "Value at Risk numerical value"@en, "风险价值数值"@zh .

:hasConfidenceLevel a owl:DatatypeProperty ;
  rdfs:domain :RiskMeasurementTool ;
  rdfs:range xsd:decimal ;
  rdfs:label "has confidence level"@en, "置信水平"@zh ;
  rdfs:comment "Confidence level for risk measurement (e.g., 0.99 for 99%)"@en, "风险测量的置信水平（如0.99表示99%）"@zh .

:hasTimeHorizonDays a owl:DatatypeProperty ;
  rdfs:domain :RiskMeasurementTool ;
  rdfs:range xsd:integer ;
  rdfs:label "has time horizon in days"@en, "持有期限（天）"@zh ;
  rdfs:comment "Time horizon for risk measurement in days"@en, "风险衡量的持有期限（天）"@zh .

:hasVolatility a owl:DatatypeProperty ;
