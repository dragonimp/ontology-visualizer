  rdfs:range xsd:decimal ;
  rdfs:label "has correlation increase"@en, "相关性增加"@zh ;
  rdfs:comment "Increase in correlation during crisis"@en, "危机期间相关性增加幅度"@zh .

:hasLiquidityGap a owl:DatatypeProperty ;
