  rdfs:range xsd:decimal ;
  rdfs:label "has NSFR value"@en, "NSFR值"@zh ;
  rdfs:comment "Net Stable Funding Ratio percentage"@en, "净稳定资金比率百分比"@zh .

:hasRiskWeightedAssets a owl:DatatypeProperty ;
  rdfs:domain :BaselIII ;
  rdfs:range xsd:decimal ;
  rdfs:label "has risk-weighted assets"@en, "风险加权资产"@zh ;
